# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: Restrict to specific Telegram user IDs
# Get your ID by messaging @userinfobot on Telegram
# For /hand, set this or ALLOWED_TELEGRAM_CHAT_IDS to enable access
ALLOWED_TELEGRAM_USER_IDS=

# Optional: Restrict /hand to specific Telegram chat IDs (groups or private chats)
# Example: -1001234567890,-1009876543210
ALLOWED_TELEGRAM_CHAT_IDS=

# Optional: Codex workspace for /hand requests
CODEX_WORKDIR=/home/qwen

# Optional: Dedicated workspace for /handresearch requests
CODEX_HANDRESEARCH_WORKDIR=/home/qwen/deep-research-coin

# Optional: Timeout for /hand requests in milliseconds
CODEX_TIMEOUT_MS=180000

# Optional: Timeout for /handresearch requests in milliseconds (set 0 to disable)
CODEX_HANDRESEARCH_TIMEOUT_MS=0

# Optional: Etherscan API Key
ETHERSCAN_API_KEY=your_etherscan_api_key_here
